# Public application URL.
# For local Docker:
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# For server behind Nginx:
# NEXT_PUBLIC_APP_URL=https://quiz.example.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Host port for the app.
# Nginx on the server should proxy to http://127.0.0.1:3000
APP_PORT=3000

# PostgreSQL.
POSTGRES_USER=cinemusic
POSTGRES_PASSWORD=change-me-db-password
POSTGRES_DB=cinemusic_quiz

# Admin session secret. Generate:
# openssl rand -base64 48
ADMIN_SESSION_SECRET=change-me-long-random-secret

# First admin user.
# Used by npm run admin:init. If an admin already exists, this is ignored.
ADMIN_USERNAME=RomanBogachev
ADMIN_PASSWORD=change-me-admin-password
ADMIN_EMAIL=
ADMIN_NAME=

# Local non-Docker development only:
# DATABASE_URL=postgresql://cinemusic:change-me-db-password@localhost:5432/cinemusic_quiz?schema=public
