# App
NODE_ENV=production
APP_PORT=3000
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
UPLOAD_DIR=/app/uploads

# PostgreSQL
POSTGRES_USER=cinemusic
POSTGRES_PASSWORD=cinemusic_password
POSTGRES_DB=cinemusic_quiz
POSTGRES_PORT=5432

# Prisma inside Docker uses the postgres service hostname.
DATABASE_URL=postgresql://cinemusic:cinemusic_password@postgres:5432/cinemusic_quiz?schema=public

# Auth/session
ADMIN_SESSION_SECRET=replace-with-a-long-random-secret

# Optional first admin user for npm run admin:init.
# If admins already exist, these values are ignored.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-admin-password
ADMIN_NAME=Admin
